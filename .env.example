# Notion API (required for dynamic content — notes, projects, bookmarks, and auto-discovered databases)
# Create an integration at https://www.notion.so/my-integrations
# Share your databases with the integration and they'll be automatically discovered
NOTION_API_KEY=

# Multi-Workspace Support (optional - for categorizing databases by workspace)
# Create separate integrations for each workspace and add their API keys here
NOTION_GATE_EC_API_KEY=
NOTION_ML_API_KEY=
NOTION_PERSONAL_API_KEY=

# Legacy Database IDs (optional - only needed if you want to override auto-discovery)
# Share each database with your integration, then copy the database ID from the URL
NOTION_NOTES_DB=
NOTION_PROJECTS_DB=
NOTION_BOOKMARKS_DB=

# Giscus Comments (optional)
# Set up at https://giscus.app
NEXT_PUBLIC_GISCUS_REPO=
NEXT_PUBLIC_GISCUS_REPO_ID=
NEXT_PUBLIC_GISCUS_CATEGORY=
NEXT_PUBLIC_GISCUS_CATEGORY_ID=

# Site URL (used for RSS feed, sitemap, OG images)
NEXT_PUBLIC_SITE_URL=https://shahbazfayaz.com
